{
  "manifest_version": 3,
  "name": "ELO Quink - Your quick bookmark new tab",
  "short_name": "ELO Quink",
  "description": "ELO Quink - Your quick bookmark new tab",
  "version": "3.1.5",
  "icons": {
    "16": "assets/logos/favicon.ico",
    "48": "assets/logos/icon-192.png",
    "128": "assets/logos/icon-512.png"
  },
  "offline_enabled": true,
  "permissions": [
    "favicon",
    "bookmarks"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "_favicon/*"
      ],
      "matches": [
        "<all_urls>"
      ],
      "extension_ids": [
        "*"
      ]
    }
  ],
  "chrome_url_overrides": {
    "newtab": "index.html"
  }
}